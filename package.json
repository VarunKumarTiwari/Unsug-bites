{
  "name": "unsung-bites-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm --workspace @unsung/mobile run start",
    "mobile:web": "npm --workspace @unsung/mobile run web",
    "mobile:ios": "npm --workspace @unsung/mobile run ios",
    "mobile:android": "npm --workspace @unsung/mobile run android"
  }
}
